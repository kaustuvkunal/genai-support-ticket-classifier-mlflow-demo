# GenAI Ticket Classifier Configuration
# ======================================
# Copy this file to `.env` and fill in the values for your setup.

# ============ GRADIO APP (Standalone) ============
# Supported LLM providers shown in the UI
SUPPORTED_PROVIDERS=groq,openai

# Active/default provider
LLM_PROVIDER=groq

# Provider display names and default models
GROQ_DISPLAY_NAME=Groq
GROQ_MODEL_NAME=llama-3.1-8b-instant
OPENAI_DISPLAY_NAME=OpenAI
OPENAI_MODEL_NAME=gpt-3.5-turbo

# Optional override for the currently selected provider
# MODEL_NAME=llama-3.1-8b-instant

# API Keys for LLM providers
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# ============ GRADIO UI Authentication ============
# Optional: Basic auth for Hugging Face Spaces or local deployment
# USERNAME=myuser
# PASSWD=mypassword

# ============ MLflow CLI (Optional) ============
# Only needed if using the src/cli.py for MLflow registration/evaluation
MLFLOW_TRACKING_URI=http://127.0.0.1:5000
PROMPT_NAME=support-ticket-classifier-prompt
MLFLOW_EXPERIMENT=Support_Ticket_Classification_project
